# Copy this file to .env for local development and fill in real values.
# .env itself is git-ignored and must never be committed.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL unset locally to fall back to SQLite.
# In production (Render), this is provided automatically by render.yaml.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional: automatic superuser creation (create_superuser.py)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
